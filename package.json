{
  "name": "enterprise-bd-os",
  "version": "0.1.0",
  "description": "Autonomous B2B business development OS \u2014 signals, prediction, outreach, content, self-optimization",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "tsx src/scheduler.ts",
    "setup": "tsx setup/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "prisma migrate dev --schema packages/database/prisma/schema.prisma",
    "db:generate": "prisma generate --schema packages/database/prisma/schema.prisma"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@inquirer/prompts": "^7.0.0",
    "@langchain/langgraph": "^0.2.0",
    "@prisma/client": "^6.0.0",
    "axios": "^1.7.0",
    "chalk": "^5.3.0",
    "cron": "^3.1.0",
    "js-yaml": "^4.1.0",
    "nodemailer": "^6.9.0",
    "openai": "^4.67.0",
    "playwright": "^1.48.0",
    "rss-parser": "^3.13.0",
    "tsx": "^4.19.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cron": "^2.4.3",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.16",
    "prisma": "^6.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma"
    ]
  }
}
